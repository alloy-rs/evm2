-pub(crate) fn load_account_code<DB: DatabaseRef>(
-    db: DB,
-    db_acc: &revm::state::AccountInfo,
-) -> Option<Bytes> {
-    db_acc.code.as_ref().map(|code| code.original_bytes()).or_else(|| {
-        if db_acc.code_hash == KECCAK_EMPTY {
