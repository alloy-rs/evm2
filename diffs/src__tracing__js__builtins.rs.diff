+        assert!(result.as_boolean().unwrap());
+
+        let result = ctx.eval(Source::from_bytes(b"bigInt(1).equals(bigInt(2))")).unwrap();
+        assert!(!result.as_boolean().unwrap());
+
+        let result = ctx.eval(Source::from_bytes(b"BigInt(0).equals(0)")).unwrap();
