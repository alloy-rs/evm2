+pub(crate) fn to_bigint(value: U256) -> JsResult<JsValue> {
+    JsBigInt::from_string(&value.to_string()).map(Into::into).ok_or_else(|| {
+        JsError::from_native(
+            JsNativeError::error().with_message("failed to convert U256 to BigInt"),
+        )
+    })
